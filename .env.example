# ===================================================
# 우나어 — 환경변수 템플릿
# ===================================================
# 이 파일을 .env.local로 복사한 후 실제 값을 채우세요
# cp .env.example .env.local
# 관리 정책: docs/spec/SECRETS_MANAGEMENT.md 참조
# ===================================================

# ── GitHub ──
GITHUB_TOKEN=

# ── Supabase ──
# Publishable key = 구 anon key (sb_publishable_*)
# Secret key = 구 service_role key (sb_secret_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Pooler (transaction mode) — 앱 런타임용
DATABASE_URL=
# Direct (session mode) — Prisma 마이그레이션용
DIRECT_URL=

# ── NextAuth v5 ──
AUTH_URL=http://localhost:3000
AUTH_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── Cloudflare R2 ──
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=unaeo-uploads
NEXT_PUBLIC_R2_PUBLIC_URL=

# ── AI Agent (Phase 2) ──
ANTHROPIC_API_KEY=
CLAUDE_MODEL_HEAVY=claude-sonnet-4-6
CLAUDE_MODEL_LIGHT=claude-haiku-4-5

# ── Slack (6채널 통합) ──
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_DASHBOARD=    # #대시보드 — 창업자 필수 확인 (브리핑+승인+critical)
SLACK_CHANNEL_REPORT=       # #리포트 — 주간 리포트, KPI, 실험
SLACK_CHANNEL_QA=           # #qa — 배포별 QA (스레드 기반)
SLACK_CHANNEL_SYSTEM=       # #시스템 — CTO/CPO 시스템 알림
SLACK_CHANNEL_LOG=          # #로그 — 통합 운영 로그 [일자리][콘텐츠][마케팅][비용]
SLACK_CHANNEL_AGENT=        # #에이전트 — 에이전트 협업/회의

# ── Sentry ──
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Admin ──
ADMIN_JWT_SECRET=

# ── Bot API Keys ──
BOT_API_KEY_JOB=
BOT_API_KEY_HUMOR=
BOT_API_KEY_STORY=
BOT_API_KEY_SEED=

# ── Google Analytics / GTM ──
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=

# ── Google AdSense ──
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-4937127825992215

# ── Coupang Partners CPS ──
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# ── X (Twitter) API ──
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# ── Meta / Threads ──
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=

# ── Cloudflare Turnstile (봇 차단 — 미설정 시 비회원 댓글 captcha 미작동) ──
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=   # Cloudflare → Turnstile → Site Key
CF_TURNSTILE_SECRET_KEY=             # Cloudflare → Turnstile → Secret Key

# ── Web Push / VAPID (푸시 알림 — 미설정 시 구독 갱신 실패) ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=        # npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:korea.age.not.matter@gmail.com

# ── Upstash Redis (Rate Limit — 미설정 시 in-memory 폴백, 서버리스 무효) ──
UPSTASH_REDIS_REST_URL=              # Upstash → Database → REST API URL
UPSTASH_REDIS_REST_TOKEN=            # Upstash → Database → REST API Token

# ── Email (Resend) ──
RESEND_API_KEY=                      # resend.com → API Keys
CONTACT_EMAIL=korea.age.not.matter@gmail.com

# ── 기능 플래그 (Feature Flags) ──
FEATURE_PUSH_TOAST=false
FEATURE_WEB_PUSH=false
# TWA 진입 게이트 긴급 OFF 스위치. 미설정/빈값=ON(기본), 'false'면 게이트 비활성.
# 클라이언트 컴포넌트라 NEXT_PUBLIC_ 접두사 필수.
NEXT_PUBLIC_TWA_GATE_ENABLED=

# ── 비회원 좋아요 ──
GUEST_LIKE_SALT=                     # 임의 랜덤 문자열 (openssl rand -hex 32)

# ── Slack 어드민 ──
SLACK_ADMIN_USER_IDS=                # 슬랙 사용자 ID 쉼표 구분 (예: U12345,U67890)

# ── App ──
NEXT_PUBLIC_APP_URL=https://age-doesnt-matter.com
NEXT_PUBLIC_KAKAO_JS_KEY=
