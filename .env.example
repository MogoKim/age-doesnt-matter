# ===================================================
# 우나어 — 환경변수 템플릿
# ===================================================
# 이 파일을 .env.local로 복사한 후 실제 값을 채우세요
# cp .env.example .env.local
# 관리 정책: docs/spec/SECRETS_MANAGEMENT.md 참조
# ===================================================

# ── GitHub ──
GITHUB_TOKEN=

# ── Supabase ──
# Publishable key = 구 anon key (sb_publishable_*)
# Secret key = 구 service_role key (sb_secret_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Pooler (transaction mode) — 앱 런타임용
DATABASE_URL=
# Direct (session mode) — Prisma 마이그레이션용
DIRECT_URL=

# ── NextAuth v5 ──
AUTH_URL=http://localhost:3000
AUTH_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── Cloudflare R2 ──
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=unaeo-uploads
NEXT_PUBLIC_R2_PUBLIC_URL=

# ── AI Agent (Phase 2) ──
ANTHROPIC_API_KEY=
CLAUDE_MODEL_HEAVY=claude-sonnet-4-6
CLAUDE_MODEL_LIGHT=claude-haiku-4-5

# ── Slack (운영 채널) ──
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_CEO_FOUNDER=
SLACK_CHANNEL_DAILY_BRIEFING=
SLACK_CHANNEL_WEEKLY_REPORT=
SLACK_CHANNEL_AGENT_MEETING=
SLACK_CHANNEL_MEETING_LOG=
SLACK_CHANNEL_ALERT_URGENT=
SLACK_CHANNEL_ALERT_SYSTEM=
SLACK_CHANNEL_ALERT_KPI=
SLACK_CHANNEL_LOG_JOBS=
SLACK_CHANNEL_LOG_CONTENT=
SLACK_CHANNEL_LOG_MARKETING=
SLACK_CHANNEL_LOG_COST=
SLACK_CHANNEL_EXPERIMENT=

# ── Sentry ──
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Admin ──
ADMIN_JWT_SECRET=

# ── Bot API Keys ──
BOT_API_KEY_JOB=
BOT_API_KEY_HUMOR=
BOT_API_KEY_STORY=
BOT_API_KEY_SEED=

# ── App ──
NEXT_PUBLIC_APP_URL=https://age-doesnt-matter.com
NEXT_PUBLIC_KAKAO_JS_KEY=
